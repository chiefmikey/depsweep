{
  "name": "depsweep",
  "version": "1.0.0",
  "type": "module",
  "description": "Automated intelligent dependency cleanup with environmental impact reporting",
  "main": "dist/index.js",
  "bin": {
    "depsweep": "dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "dev:run": "npm run build && node dist/index.js",
    "dev:test": "npm run build && node dist/index.js --help",
    "dev:demo": "npm run build && node dist/index.js --measure-impact --dry-run --verbose",
    "test": "jest --no-cache",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:check": "jest --coverage",
    "test:e2e": "jest --testPathPatterns=e2e.test.ts --coverage --coverageThreshold.global.statements=30 --coverageThreshold.global.branches=20 --coverageThreshold.global.functions=20 --coverageThreshold.global.lines=30",
    "test:unit": "jest --testPathPatterns=unit.test.ts --coverage",
    "test:performance": "jest --testPathPatterns=performance.test.ts --coverage",
    "test:ci": "npm run test:coverage:check",
    "coverage:analyze": "jest --coverage --coverageThreshold.global.statements=100 --coverageThreshold.global.branches=100 --coverageThreshold.global.functions=100 --coverageThreshold.global.lines=100",
    "coverage:report": "jest --coverage --passWithNoTests",
    "coverage:detailed": "npm run test:coverage && node scripts/coverage-analysis.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist coverage node_modules package-lock.json",
    "prepublishOnly": "npm run build && npm run test:ci && npm run security",
    "validate": "npm run type-check && npm run lint && npm run test:coverage:check",
    "quality": "npm run lint && npm run format:check && npm run type-check",
    "security": "npm audit --audit-level=moderate",
    "update": "npm update && npm audit fix",
    "docs": "npm run build && node dist/index.js --help",
    "demo": "npm run build && node dist/index.js --measure-impact --dry-run --verbose",
    "benchmark": "npm run build && node dist/benchmark.js",
    "analyze": "npm run build && npm run analyze:bundle",
    "analyze:bundle": "webpack-bundle-analyzer dist/stats.json || echo 'Bundle analysis not available'",
    "precommit": "npm run lint && npm run test:unit",
    "prepush": "npm run test:ci",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,vue,svelte}": [
      "eslint --fix --no-error-on-unmatched-pattern",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": ["prettier --write"]
  },
  "keywords": [
    "dependencies",
    "cleanup",
    "unused",
    "environmental",
    "impact",
    "carbon",
    "energy",
    "sustainability",
    "green",
    "npm",
    "yarn",
    "pnpm",
    "node",
    "typescript",
    "javascript"
  ],
  "author": "Mikl Wolfe <wolfemikl@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chiefmikey/depsweep.git"
  },
  "bugs": {
    "url": "https://github.com/chiefmikey/depsweep/issues"
  },
  "homepage": "https://github.com/chiefmikey/depsweep#readme",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@babel/parser": "^7.25.0",
    "@babel/traverse": "^7.25.0",
    "@babel/types": "^7.25.0",
    "chalk": "^5.6.0",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.0",
    "find-up": "^8.0.0",
    "globby": "^16.1.1",
    "isbinaryfile": "^5.0.6",
    "lru-cache": "^11.2.1",
    "node-fetch": "^3.3.2",
    "ora": "^9.3.0",
    "shell-escape": "^0.2.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@mikey-pro/prettier-config": "^10.3.4",
    "@types/cli-progress": "^3.11.6",
    "@types/jest": "^30.0.0",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^25.3.3",
    "@types/shell-escape": "^0.2.3",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "jest": "^30.1.1",
    "lint-staged": "^17.0.5",
    "mikey-pro": "^10.3.4",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "files": ["dist/**/*", "README.md", "LICENSE", "package.json"],
  "publishConfig": {
    "access": "public"
  }
}
